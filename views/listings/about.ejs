<% layout("/layouts/boilerplate") %>

<style>
  :root {
    --primary-color: #fe424d;
    --primary-hover: #e03b44;
    --dark-bg: #1e1e24;
    --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    --card-shadow-hover: 0 20px 40px rgba(254, 66, 77, 0.15);
    --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .about-hero {
    position: relative;
    background: linear-gradient(135deg, #fff5f5 0%, #fff0f0 100%);
    border-radius: 2rem;
    padding: 4rem 2rem;
    margin-top: 2rem;
    margin-bottom: 4rem;
    overflow: hidden;
    box-shadow: var(--card-shadow);
  }

  .about-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(254, 66, 77, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 1;
  }

  .about-hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .hero-tag {
    background-color: rgba(254, 66, 77, 0.1);
    color: var(--primary-color);
    padding: 0.5rem 1.2rem;
    border-radius: 2rem;
    font-size: 0.9rem;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    color: #222222;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-size: 1.2rem;
    color: #555555;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .tech-badge {
    background-color: #f8f9fa;
    border: 1px solid #e9ecef;
    color: #495057;
    padding: 0.4rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    margin-right: 0.5rem;
    margin-bottom: 0.5rem;
    display: inline-block;
    transition: var(--transition);
  }

  .tech-badge:hover {
    background-color: var(--primary-color);
    color: #ffffff;
    border-color: var(--primary-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(254, 66, 77, 0.2);
  }

  /* Section Styles */
  .section-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #222222;
    margin-bottom: 3rem;
    text-align: center;
    position: relative;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background-color: var(--primary-color);
    margin: 0.8rem auto 0;
    border-radius: 2px;
  }

  /* Features Grid */
  .feature-card {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.03);
    border-radius: 1.5rem;
    padding: 2.5rem 2rem;
    height: 100%;
    box-shadow: var(--card-shadow);
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: var(--primary-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: var(--transition);
  }

  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--card-shadow-hover);
  }

  .feature-card:hover::before {
    transform: scaleX(1);
  }

  .feature-icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 1.2rem;
    background-color: rgba(254, 66, 77, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: var(--transition);
  }

  .feature-card:hover .feature-icon-wrapper {
    background-color: var(--primary-color);
  }

  .feature-card:hover .feature-icon-wrapper i {
    color: #ffffff;
    transform: scale(1.1);
  }

  .feature-icon-wrapper i {
    font-size: 1.6rem;
    color: var(--primary-color);
    transition: var(--transition);
  }

  .feature-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: #222222;
    margin-bottom: 1rem;
  }

  .feature-desc {
    color: #666666;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Stats Section */
  .stats-section {
    background-color: #f8f9fa;
    border-radius: 2rem;
    padding: 3rem 2rem;
    margin: 4rem 0;
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem 0;
  }

  .stat-num {
    font-size: 3rem;
    font-weight: 800;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 1rem;
    font-weight: 600;
    color: #495057;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Developer Info */
  .dev-section {
    margin-bottom: 5rem;
  }

  .dev-card {
    background: linear-gradient(135deg, #1e1e24 0%, #111115 100%);
    border-radius: 2rem;
    padding: 3.5rem;
    color: #ffffff;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
    position: relative;
    overflow: hidden;
  }

  .dev-card::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(254, 66, 77, 0.15) 0%, transparent 75%);
    border-radius: 50%;
  }

  .dev-subtitle {
    color: var(--primary-color);
    font-weight: 600;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
  }

  .dev-name {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
  }

  .dev-bio {
    font-size: 1.1rem;
    color: #bcbcbc;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 2rem;
  }

  .dev-socials a {
    color: #ffffff;
    font-size: 1.5rem;
    margin-right: 1.5rem;
    transition: var(--transition);
    display: inline-block;
  }

  .dev-socials a:hover {
    color: var(--primary-color);
    transform: translateY(-3px);
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animated {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }
</style>

<div class="container py-2">
  <!-- Hero Section -->
  <header class="about-hero animated">
    <div class="row align-items-center">
      <div class="col-lg-8 about-hero-content">
        <span class="hero-tag">About the Project</span>
        <h1 class="hero-title">Welcome to WanderLust</h1>
        <p class="hero-desc">
          WanderLust is a sophisticated, full-stack travel accommodation platform designed to connect wanderers with extraordinary hosts and unique places to stay. From cozy mountain log cabins to sleek city apartments, WanderLust makes travel planning immersive, transparent, and completely secure.
        </p>
        <div class="mb-4">
          <span class="tech-badge">Node.js</span>
          <span class="tech-badge">Express</span>
          <span class="tech-badge">MongoDB Atlas</span>
          <span class="tech-badge">EJS Templates</span>
          <span class="tech-badge">Passport.js Auth</span>
          <span class="tech-badge">Cloudinary</span>
          <span class="tech-badge">Bootstrap 5</span>
          <span class="tech-badge">MVC Architecture</span>
        </div>
        <a href="/listings" class="btn btn-danger btn-lg px-4 py-2" style="background-color: var(--primary-color); border: none; border-radius: 10px; font-weight: 600;">
          Explore Listings <i class="fa-solid fa-arrow-right ms-2"></i>
        </a>
      </div>
    </div>
  </header>

  <!-- Features Grid -->
  <section class="mb-5">
    <h2 class="section-title animated delay-1">Key Platform Features</h2>
    <div class="row g-4 mt-2">
      <!-- Feature 1 -->
      <div class="col-md-6 col-lg-3 animated delay-1">
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <i class="fa-solid fa-house-chimney"></i>
          </div>
          <h3 class="feature-title">Listing CRUD</h3>
          <p class="feature-desc">
            Seamlessly host properties. Create, view, update, and manage unique travel listings with comprehensive details and pricing.
          </p>
        </div>
      </div>
      <!-- Feature 2 -->
      <div class="col-md-6 col-lg-3 animated delay-2">
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <i class="fa-solid fa-shield-halved"></i>
          </div>
          <h3 class="feature-title">Secure Auth</h3>
          <p class="feature-desc">
            Powered by Passport.js. Strict authentication and authorization guards ensure only owners can modify listings and reviews.
          </p>
        </div>
      </div>
      <!-- Feature 3 -->
      <div class="col-md-6 col-lg-3 animated delay-3">
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <i class="fa-solid fa-cloud-arrow-up"></i>
          </div>
          <h3 class="feature-title">Cloud Uploads</h3>
          <p class="feature-desc">
            Automated image parsing using Multer and storage in Cloudinary, ensuring listing graphics load instantaneously in production.
          </p>
        </div>
      </div>
      <!-- Feature 4 -->
      <div class="col-md-6 col-lg-3 animated delay-4">
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <i class="fa-solid fa-star-half-stroke"></i>
          </div>
          <h3 class="feature-title">Interactive Reviews</h3>
          <p class="feature-desc">
            Share feedback with an interactive 1-to-5 star rating system and real-time reviews to build credibility and trust.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Banner -->
  <section class="stats-section animated delay-3">
    <div class="row justify-content-center">
      <div class="col-md-4 stat-item">
        <div class="stat-num">100%</div>
        <div class="stat-label">Secure Sessions</div>
      </div>
      <div class="col-md-4 stat-item">
        <div class="stat-num">MVC</div>
        <div class="stat-label">Architecture Flow</div>
      </div>
      <div class="col-md-4 stat-item">
        <div class="stat-num">Cloud</div>
        <div class="stat-label">Hosted Storage</div>
      </div>
    </div>
  </section>

  <!-- Author Section -->
  <section class="dev-section animated delay-4">
    <div class="dev-card">
      <div class="row align-items-center">
        <div class="col-lg-8 position-relative" style="z-index: 2;">
          <div class="dev-subtitle">Project Architect</div>
          <h2 class="dev-name">Kruthik Pramatha</h2>
          <p class="dev-bio">
            A software engineer passionate about designing and building scalable, robust web applications. WanderLust represents the synthesis of production-ready backend design patterns, strict validation controls, and user experience excellence.
          </p>
          <div class="dev-socials">
            <a href="https://github.com/Kruthik009" target="_blank" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
            <a href="https://www.linkedin.com/in/kruthik-pramatha-8971852a8/" target="_blank" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
            <a href="https://github.com/Kruthik009/WanderLust" target="_blank" aria-label="Project Repository"><i class="fa-solid fa-code"></i></a>
            <a href="https://wanderlust-ysw7.onrender.com" target="_blank" aria-label="Live Site"><i class="fa-solid fa-globe"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
